# Public app origin
CORS_ORIGIN=https://cup.axiia.ai

# Required secrets
JWT_SECRET=replace-with-a-long-random-secret
SILICONFLOW_API_KEY=replace-with-your-siliconflow-key

# Registration
REGISTRATION_CODE=axiia_cup

# API runtime
PORT=3001
ENABLE_WORKER=true
WORKER_CONCURRENCY=8
AXIIA_DB_PATH=/data/axiia.db

# Docker host paths / ports
AXIIA_DATA_DIR=./data
WEB_HOST_PORT=8200

# Leave empty to use same-origin /api requests through nginx
VITE_API_URL=
