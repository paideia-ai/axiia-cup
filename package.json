{
  "name": "axiia-cup",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel --filter=@axiia/web --filter=@axiia/api",
    "dev:api": "bun run --filter @axiia/api dev",
    "dev:web": "bun run --filter @axiia/web dev",
    "dev:cli": "bun run --filter @axiia/cli dev",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "bun-types": "^1.2.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  }
}
